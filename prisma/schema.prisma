generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ExpenseSource {
  WEB
  TELEGRAM
  SHORTCUT
}

enum SpaceRole {
  OWNER
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum SplitType {
  EQUAL
  PERCENTAGE
  EXACT
  SOLO
}

enum IncomeFrequency {
  ONCE
  WEEKLY
  BIWEEKLY
  MONTHLY
  YEARLY
}

model User {
  id                   String        @id @default(cuid())
  email                String        @unique
  name                 String
  passwordHash         String        @map("password_hash")
  apiToken             String        @unique @default(cuid()) @map("api_token")
  telegramChatId       String?       @map("telegram_chat_id")
  telegramLinkCode     String?       @map("telegram_link_code")
  telegramLinkCodeExp  DateTime?     @map("telegram_link_code_exp")
  defaultCurrency      String        @default("COP") @map("default_currency")
  timezone             String        @default("America/Bogota")
  defaultSpaceId       String?       @map("default_space_id")
  onboardingCompleted  Boolean       @default(false) @map("onboarding_completed")
  createdAt            DateTime      @default(now()) @map("created_at")

  categories       Category[]
  expenses         Expense[]
  spaceMemberships SpaceMember[]
  spacesCreated    Space[]           @relation("SpaceCreator")
  budgets          Budget[]
  defaultSpace     Space?            @relation("DefaultSpace", fields: [defaultSpaceId], references: [id], onDelete: SetNull)
  sentInvitations  SpaceInvitation[] @relation("InvitedBy")
  incomes          Income[]
  splitsPaidBy     ExpenseSplit[]    @relation("SplitPaidBy")
  splitsOwedBy     ExpenseSplit[]    @relation("SplitOwedBy")
  settlementsFrom  Settlement[]      @relation("SettlementFrom")
  settlementsTo    Settlement[]      @relation("SettlementTo")
  savingsGoals     SavingsGoal[]

  @@map("users")
}

model Category {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  emoji     String
  color     String
  isDefault Boolean  @default(false) @map("is_default")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses Expense[]
  budgets  Budget[]

  @@index([userId])
  @@map("categories")
}

model Expense {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  spaceId       String?       @map("space_id")
  categoryId    String        @map("category_id")
  merchant      String
  amount        Float
  currency      String
  amountUsd     Float         @map("amount_usd")
  descriptionAi String?       @map("description_ai")
  source        ExpenseSource @default(WEB)
  createdAt     DateTime      @default(now()) @map("created_at")

  splitType SplitType? @map("split_type")

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  space    Space?         @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  category Category       @relation(fields: [categoryId], references: [id])
  splits   ExpenseSplit[]

  @@index([userId, createdAt])
  @@index([spaceId])
  @@map("expenses")
}

model Space {
  id         String   @id @default(cuid())
  name       String
  createdBy  String   @map("created_by")
  inviteCode String   @unique @default(cuid()) @map("invite_code")
  createdAt  DateTime @default(now()) @map("created_at")

  creator         User              @relation("SpaceCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  members         SpaceMember[]
  expenses        Expense[]
  defaultForUsers User[]            @relation("DefaultSpace")
  invitations     SpaceInvitation[]
  incomes         Income[]
  settlements     Settlement[]

  @@map("spaces")
}

model SpaceMember {
  id       String    @id @default(cuid())
  spaceId  String    @map("space_id")
  userId   String    @map("user_id")
  role     SpaceRole @default(MEMBER)
  joinedAt DateTime  @default(now()) @map("joined_at")

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([spaceId, userId])
  @@map("space_members")
}

model Budget {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  categoryId     String   @map("category_id")
  monthlyLimitUsd Float   @map("monthly_limit_usd")
  createdAt      DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@map("budgets")
}

model SpaceInvitation {
  id        String           @id @default(cuid())
  spaceId   String           @map("space_id")
  email     String
  token     String           @unique @default(cuid())
  status    InvitationStatus @default(PENDING)
  invitedBy String           @map("invited_by")
  expiresAt DateTime         @map("expires_at")
  createdAt DateTime         @default(now()) @map("created_at")

  space   Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  inviter User  @relation("InvitedBy", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([email])
  @@map("space_invitations")
}

model Income {
  id        String          @id @default(cuid())
  userId    String          @map("user_id")
  name      String
  amount    Float
  currency  String
  amountUsd Float           @map("amount_usd")
  frequency IncomeFrequency @default(MONTHLY)
  isActive  Boolean         @default(true) @map("is_active")
  nextDate  DateTime?       @map("next_date")
  spaceId   String?         @map("space_id")
  notes     String?
  createdAt DateTime        @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  space Space? @relation(fields: [spaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("incomes")
}

model ExpenseSplit {
  id          String   @id @default(cuid())
  expenseId   String   @map("expense_id")
  paidByUserId String  @map("paid_by_user_id")
  owedByUserId String  @map("owed_by_user_id")
  amountUsd   Float    @map("amount_usd")
  isSettled   Boolean  @default(false) @map("is_settled")
  settledAt   DateTime? @map("settled_at")
  createdAt   DateTime @default(now()) @map("created_at")

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  paidBy  User    @relation("SplitPaidBy", fields: [paidByUserId], references: [id], onDelete: Cascade)
  owedBy  User    @relation("SplitOwedBy", fields: [owedByUserId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@index([owedByUserId, isSettled])
  @@index([paidByUserId])
  @@map("expense_splits")
}

model Settlement {
  id         String   @id @default(cuid())
  spaceId    String   @map("space_id")
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  amountUsd  Float    @map("amount_usd")
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  space    Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  fromUser User  @relation("SettlementFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User  @relation("SettlementTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([spaceId])
  @@map("settlements")
}

model SavingsGoal {
  id              String               @id @default(cuid())
  userId          String               @map("user_id")
  name            String
  icon            String               @default("🎯")
  targetAmountUsd Float                @map("target_amount_usd")
  currentAmountUsd Float               @default(0) @map("current_amount_usd")
  deadline        DateTime?
  isCompleted     Boolean              @default(false) @map("is_completed")
  createdAt       DateTime             @default(now()) @map("created_at")

  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions SavingsContribution[]

  @@index([userId])
  @@map("savings_goals")
}

model SavingsContribution {
  id           String      @id @default(cuid())
  goalId       String      @map("goal_id")
  amountUsd    Float       @map("amount_usd")
  note         String?
  createdAt    DateTime    @default(now()) @map("created_at")

  goal SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("savings_contributions")
}
